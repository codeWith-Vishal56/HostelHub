<% layout("/layouts/boilerplate") %>

<div class="container mt-4">

  <h2 class="mb-3">🏠 Roommate Finder</h2>

  <!-- Top Buttons -->
  <div class="mb-3 d-flex gap-2">
    <a href="/roommates/new" class="btn btn-success">
      ➕ Post Requirement
    </a>

    <a href="/roommates/match" class="btn btn-primary">
      🤝 Find Matches
    </a>
  </div>

  <% if(posts.length === 0){ %>

    <div class="alert alert-warning text-center">
      No roommate posts yet. Be the first to post!
    </div>

  <% } %>

  <div class="row">

    <% posts.forEach(post => { %>

      <div class="col-md-4">
        <div class="card mb-4 shadow-sm">

          <div class="card-body">

            <h5 class="card-title">
              📍 <%= post.city %>
            </h5>

            <p>💰 Budget: ₹<%= post.budget %></p>

            <p><%= post.description %></p>

            <hr>

            <p>📞 Contact: <%= post.contactInfo %></p>

          </div>

        </div>
      </div>

    <% }) %>

  </div>

</div>