<% layout("/layouts/boilerplate") %>

<!-- ✅ Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

<div class="container mt-4">

  <!-- TITLE -->
  <h2 class="mb-2">
    <%= hostel.title %>

    <% if(hostel.isVerified){ %>
      <span class="badge bg-success ms-2">✔ Verified</span>
    <% } %>
  </h2>

  <!-- SUSPICIOUS WARNING -->
  <% if(hostel.isSuspicious){ %>
    <div class="alert alert-danger">
      ⚠ Suspicious Listing — Proceed Carefully
    </div>
  <% } %>

  <!-- IMAGE -->
  <% if(hostel.images && hostel.images.length > 0){ %>
    <img 
      src="<%= hostel.images[0].url %>" 
      class="img-fluid mb-3 rounded shadow-sm"
      style="max-height: 400px; object-fit: cover; width: 100%;"
    />
  <% } %>

  <!-- DETAILS CARD -->
  <div class="card p-3 shadow-sm">

    <p><%= hostel.description %></p>

    <p><strong>📍 Location:</strong> <%= hostel.location %></p>

    <p><strong>💰 Price:</strong> ₹<%= hostel.price %></p>

    <p><strong>🛏 Room Type:</strong> <%= hostel.roomType %></p>

    <% if(hostel.phone){ %>
      <p><strong>📞 Phone:</strong> <%= hostel.phone %></p>
    <% } %>

    <% if(hostel.email){ %>
      <p><strong>📧 Email:</strong> <%= hostel.email %></p>
    <% } %>

  </div>

  <!-- MAP SECTION -->
  <div class="mt-4">
    <h5>📍 Location on Map</h5>

    <% if(hostel.geometry && hostel.geometry.coordinates && hostel.geometry.coordinates.length === 2){ %>
      <div id="map" style="height: 400px; border-radius: 10px;" class="shadow-sm"></div>
    <% } else { %>
      <div class="alert alert-warning">
        ⚠ Location coordinates not available for this hostel
      </div>
    <% } %>
  </div>

  <!-- ACTION BUTTONS -->
  <div class="mt-3 d-flex gap-2">
    <a href="/hostels/<%= hostel._id %>/edit" class="btn btn-warning">
      ✏ Edit
    </a>

    <form action="/hostels/<%= hostel._id %>?_method=DELETE" method="POST">
      <button class="btn btn-danger">🗑 Delete</button>
    </form>
  </div>

  <hr>

  <!-- REPORT SYSTEM -->
  <h5>🚨 Report this listing</h5>

  <form action="/hostels/<%= hostel._id %>/report" method="POST">
    <textarea 
      name="reason" 
      class="form-control mb-2" 
      placeholder="Why are you reporting this listing?"
      required
    ></textarea>

    <button class="btn btn-outline-danger">
      Report Listing
    </button>
  </form>

</div>

<!-- ✅ Leaflet JS -->
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<!-- ✅ MAP SCRIPT -->
<% if(hostel.geometry && hostel.geometry.coordinates && hostel.geometry.coordinates.length === 2){ %>
<script>
  const hostel = <%- JSON.stringify(hostel) %>;

  const coords = hostel.geometry.coordinates;

  const lat = parseFloat(coords[1]);
  const lng = parseFloat(coords[0]);

  // Extra safety
  if (!isNaN(lat) && !isNaN(lng)) {

    const map = L.map('map').setView([lat, lng], 15);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    const marker = L.marker([lat, lng]).addTo(map);

    marker.bindPopup(`
      <b>${hostel.title}</b><br>
      ${hostel.location}<br>
      ₹${hostel.price}
    `).openPopup();

  }
</script>
<% } %>