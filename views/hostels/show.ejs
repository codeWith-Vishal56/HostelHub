<% layout("/layouts/boilerplate") %>

<h2><%= hostel.title %></h2>

<img src="<%= hostel.images[0]?.url %>" class="img-fluid mb-3" />

<p><%= hostel.description %></p>

<p>Location: <%= hostel.location %></p>

<p>Price: ₹<%= hostel.price %></p>

<p>Room Type: <%= hostel.roomType %></p>

<a href="/hostels/<%= hostel._id %>/edit" class="btn btn-warning">Edit</a>

<form action="/hostels/<%= hostel._id %>?_method=DELETE" method="POST">
  <button class="btn btn-danger mt-2">Delete</button>
</form>
