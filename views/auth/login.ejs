<% layout("/layouts/boilerplate") %>

<h2>Login</h2>

<form action="/login" method="POST">
  <input class="form-control mb-2" name="email" placeholder="Email" />

  <input
    type="password"
    class="form-control mb-2"
    name="password"
    placeholder="Password"
  />

  <button class="btn btn-primary">Login</button>
</form>
